---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';

// 💡 注意：这里我帮你把路径改成了正确的 ../pages/.logo/...
import myLogo from '../pages/.logo/logo white copy.png';
---

<header>
    <nav>
        <h2>
            <a href="/" class="brand-link">
                <img src={myLogo.src} alt="OUCS Logo" class="nav-logo" />
                {SITE_TITLE}
            </a>
        </h2> 
        
        <div class="internal-links">
            <HeaderLink href="/">首页</HeaderLink>
            <HeaderLink href="/blog">文章/动态</HeaderLink>
            <HeaderLink href="/about">关于我们</HeaderLink>
        </div>
    </nav>
</header>

<style>
    header {
        margin: 0;
        padding: 1em;
        /* 💡 1. 背景色改成红色（你可以修改 #cc0000 换成你喜欢的红） */
        background: #500f0a; 
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(0, 0, 0, 0.1); 
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2); 
    }
    
    nav { display: flex; align-items: center; justify-content: space-between; max-width: 900px; margin: 0 auto; }
    
    .brand-link {
        display: flex;
        align-items: center;
        gap: 12px; 
    }
    
    .nav-logo {
        width: 36px; 
        height: 36px;
        object-fit: contain;
    }

    h2 { margin: 0; font-size: 1.5em; }
    /* 💡 2. 左上角标题文字改成纯白 */
    h2 a, h2 a:hover { color: #ffffff; text-decoration: none; } 
    
    .internal-links { display: flex; gap: 1.5em; }
    /* 💡 3. 右侧导航链接改成带一点透明度的白色 */
    .internal-links a { color: rgba(255, 255, 255, 0.8); font-weight: bold; padding: 0.5em 0; transition: color 0.2s; }
    /* 💡 4. 鼠标悬停（hover）或者当前所在页面（active）时，变成纯白色 */
    .internal-links a:hover, .internal-links a.active { color: #ffffff; text-decoration: none; }
</style>