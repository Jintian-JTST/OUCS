---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2> <div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章/动态</HeaderLink>
			<HeaderLink href="/about">关于我们</HeaderLink>
		</div>
		</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 1em;
		background: rgba(255, 255, 255, 0.95); /* 半透明白底 */
		position: sticky;
		top: 0;
		z-index: 100;
		border-bottom: 1px solid rgba(0, 0, 0, 0.05); /* 浅灰色底边 */
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05); /* 加一点淡淡的阴影 */
	}
	nav { display: flex; align-items: center; justify-content: space-between; max-width: 900px; margin: 0 auto; }
	h2 { margin: 0; font-size: 1.5em; }
	h2 a, h2 a:hover { color: var(--accent); text-decoration: none; } /* 左上角名字改成牛津蓝 */
	.internal-links { display: flex; gap: 1.5em; }
	.internal-links a { color: #555; font-weight: bold; padding: 0.5em 0; }
	.internal-links a:hover, .internal-links a.active { color: var(--accent); text-decoration: none; }
</style>