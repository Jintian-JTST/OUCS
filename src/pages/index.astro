---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <BaseHead title={`首页 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header />
        <main class="home-container">
            
            <div class="hero">
				<img src="./.logo/logo_zi_transparent copy.png" alt="OUCS Logo" class="hero-logo" />

                <h1>
                    <span class="outline-text">OUCS</span><br />
                    牛津大学中国学生会
                </h1>
                <p class="subtitle">连接牛津华人，传承中华文化</p>
                <a href="/about" class="hero-cta">了解我们</a>
            </div>

            <div class="features">
                <h2>探索我们的世界</h2>
                <div class="feature-grid">
                    
                    <div class="feature-card">
                        <div class="feature-card-content">
                            <span class="card-icon-wrapper"><span class="card-icon">📢</span></span>
                            <h3>最新动态</h3>
                            <p>活动回顾、招新公告，与公众号同步。</p>
                            <a href="/blog" class="card-link">查看全部 <span class="arrow">→</span></a>
                        </div>
                    </div>

                    <div class="feature-card">
                        <div class="feature-card-content">
                            <span class="card-icon-wrapper"><span class="card-icon">📅</span></span>
                            <h3>精彩活动</h3>
                            <p>从 Formal exchange 到节日晚会，期待你的参与。</p>
                            <a href="/blog" class="card-link">近期活动 <span class="arrow">→</span></a>
                        </div>
                    </div>

                    <div class="feature-card">
                        <div class="feature-card-content">
                            <span class="card-icon-wrapper"><span class="card-icon">🤝</span></span>
                            <h3>合作伙伴</h3>
                            <p>与全英及跨国组织合作，拓展平台。</p>
                            <a href="/blog" class="card-link">了解更多 <span class="arrow">→</span></a>
                        </div>
                    </div>

                </div>
            </div>

            <div class="join">
                <div class="join-bg"></div>
                <h1>准备好成为我们的一员了吗？</h1>
                <p>无论是作为参与者还是 Committee，我们都欢迎你的到来。</p>
                <a href="/about#join" class="hero-cta join-cta">立即加入</a>
            </div>

        </main>
        <Footer />
    </body>
</html>

<style>
    /* 💡 全局背景统一为纯白 */
    :global(body) {
        background-color: #ffffff;
        color: #1a1a1a;
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        overflow-x: hidden;
    }

    .home-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* 💡 [Hero Section] */
    .hero {
        height: 85vh;
        min-height: 600px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        position: relative;
    }

    .hero h1 {
        font-size: clamp(3.5rem, 8vw, 6.5rem);
        line-height: 1.05;
        letter-spacing: -0.02em;
        font-weight: 800;
        color: #111;
        margin: 0;
    }

    .hero h1 .outline-text {
        color: transparent;
        -webkit-text-stroke: 1.5px #111;
        opacity: 0.15;
        display: block;
        margin-bottom: 0.2rem;
    }

    .hero .subtitle {
        font-size: 1.4rem;
        color: #555;
        margin-top: 1.5rem;
        margin-bottom: 3.5rem;
        font-weight: 400;
        letter-spacing: 0.02em;
    }

    .hero-cta {
        display: inline-block;
        background-color: #111;
        color: #fff;
        padding: 1rem 2.5rem;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1.1rem;
        transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1);
    }

    .hero-cta:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        background-color: #002147; 
    }

    /* 💡 [Features Section] */
    .features {
        padding: 6rem 0 10rem;
    }

    .features h2 {
        font-size: 2.5rem;
        letter-spacing: -0.02em;
        color: #111;
        margin-bottom: 4rem;
        text-align: center;
        font-weight: 800;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    /* 💡 纯白卡片保留极淡边框和微弱阴影以防与背景糊在一起 */
    .feature-card {
        background: #ffffff;
        border: 1px solid #eaeaea;
        padding: 3rem 2.5rem;
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        cursor: pointer;
        position: relative;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.03);
    }

    .feature-card:hover {
        transform: translateY(-8px);
        border-color: #d1d5db;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    }

    .card-icon-wrapper {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 64px;
        height: 64px;
        background: #f3f4f6;
        border-radius: 16px;
        margin-bottom: 1.5rem;
    }

    .card-icon {
        font-size: 2rem;
    }

    .feature-card h3 {
        font-size: 1.5rem;
        color: #111;
        margin-top: 0;
        margin-bottom: 1rem;
        font-weight: 700;
    }

    .feature-card p {
        font-size: 1.05rem;
        color: #666;
        line-height: 1.6;
        margin-bottom: 2rem;
    }

    .card-link {
        color: #002147;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: gap 0.3s ease;
    }

    .card-link:hover {
        gap: 0.8rem;
        color: #0056b3;
    }

    /* 💡 [Join Section] */
    .join {
        padding: 8rem 0;
        text-align: center;
        position: relative;
        margin-top: 2rem;
    }

    .join-bg {
        position: absolute;
        top: 0; left: 50%; transform: translateX(-50%);
        width: 100vw; height: 100%;
        background: #ffffff; /* 底部区域背景也设为纯白 */
        z-index: -1;
    }

    .join h1 {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
        line-height: 1.2;
        margin-bottom: 1.5rem;
        color: #111;
        font-weight: 800;
    }

    .join p {
        font-size: 1.2rem;
        color: #666; /* 适配白底的文字颜色 */
        margin-bottom: 3.5rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.6;
    }

    /* 底部纯黑按钮 */
    .join-cta {
        background-color: #000000;
        color: #ffffff;
    }
    .join-cta:hover {
        background-color: #333333; /* 深灰色悬停效果 */
        color: #ffffff;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    }

    /* 响应式适配 */
    @media (max-width: 900px) {
        .hero {
            align-items: center;
            text-align: center;
        }
        .feature-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .join {
            padding: 6rem 0;
        }
    }
</style>